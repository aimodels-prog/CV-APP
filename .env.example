GEMINI_API_KEY=
PORT=3000

# Local PostgreSQL example. Replace the credentials and database name as needed.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/via_cv
DATABASE_POOL_MAX=10

# Leave DATABASE_SSL unset for a local server. DigitalOcean connection strings
# normally include sslmode=require. Use these only when explicit SSL overrides
# are required by the target environment.
DATABASE_SSL=
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Required before PostgreSQL write endpoints are enabled in production.
# Send this value in the x-admin-token request header.
API_ADMIN_TOKEN=

# PostgreSQL is the only Stage 6 data engine.
VITE_POSTGRES_API_BASE=/api/v2
