GEMINI_API_KEY=
PORT=3000

# VIA Portal SSO. Use a strong shared secret of at least 32 bytes and never
# expose it through a VITE_ variable.
PORTAL_SSO_SECRET=
PORTAL_SSO_ISSUER=via-portal
PORTAL_SSO_AUDIENCE=via-cv-generation
PORTAL_URL=https://portal.via-int.com
PORTAL_SSO_AUTO_CREATE_USERS=true
PORTAL_SESSION_TTL_HOURS=12

# Local PostgreSQL example. Replace the credentials and database name as needed.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/via_cv
DATABASE_POOL_MAX=10

# Leave DATABASE_SSL unset for local PostgreSQL and DigitalOcean connection
# strings. DigitalOcean's sslmode=require is handled with libpq-compatible TLS.
# Set DATABASE_CA_CERT to enable full certificate verification when available.
DATABASE_SSL=
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_CA_CERT=

# Optional emergency server-to-server write token. Browser users are authorized
# by their VIA Portal session; never expose this value through a VITE_ variable.
API_ADMIN_TOKEN=

# PostgreSQL is the only Stage 6 data engine.
VITE_POSTGRES_API_BASE=/api/v2
